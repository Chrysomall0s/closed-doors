# Godot 4+ specific ignores
.godot/
/android/

# Import cache (safe to delete, regenerates automatically)
.import/

# Export files (only if you export builds)
export.cfg
export_presets.cfg

# Temporary files
*.tmp
*.import

# OS junk files (very common)
.DS_Store
Thumbs.db

# Mono / .NET (ONLY if you used C# version)
.mono/
*.sln
*.csproj